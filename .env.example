# ==============================================
# IBM Bob API Configuration (REQUIRED)
# ==============================================
# Get your Bob API key from IBM Cloud Console
# https://cloud.ibm.com/
BOB_API_KEY=your_bob_api_key_here

# IBM Bob API Endpoint (Optional - defaults to IBM's endpoint)
BOB_API_ENDPOINT=https://api.ibm.com/bob/v1

# IBM Bob Model (Optional - defaults to recommended model)
BOB_MODEL=ibm/granite-code-34b

# ==============================================
# Application Configuration
# ==============================================
# Environment: development, production, test
NODE_ENV=development

# Application URL (automatically set by Vercel in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable/Disable Bob Integration
NEXT_PUBLIC_ENABLE_BOB_INTEGRATION=true

# Enable/Disable Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ==============================================
# GitHub Integration (Optional - Future Feature)
# ==============================================
# GitHub Personal Access Token (for repository analysis)
GITHUB_TOKEN=your_github_token_here

# GitHub App Configuration (for GitHub App integration)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ==============================================
# Analytics & Monitoring (Optional)
# ==============================================
# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================
# Database (Optional - Future Feature)
# ==============================================
# PostgreSQL Database URL (for storing analysis results)
# DATABASE_URL=postgresql://user:password@localhost:5432/contractproof

# Redis Cache (for caching analysis results)
# REDIS_URL=redis://localhost:6379

# ==============================================
# Email Notifications (Optional - Future Feature)
# ==============================================
# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# SendGrid API Key (alternative to SMTP)
# SENDGRID_API_KEY=your_sendgrid_api_key

# ==============================================
# Rate Limiting (Optional)
# ==============================================
# Maximum requests per minute per user
RATE_LIMIT_MAX_REQUESTS=10

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# ==============================================
# Feature Flags (Optional)
# ==============================================
# Enable experimental features
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_FEATURES=false

# Enable ML-based drift prediction
NEXT_PUBLIC_ENABLE_ML_PREDICTION=false

# Enable GitHub App integration
NEXT_PUBLIC_ENABLE_GITHUB_APP=false

# ==============================================
# Development Tools (Development Only)
# ==============================================
# Enable debug logging
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Skip SSL verification (development only)
NODE_TLS_REJECT_UNAUTHORIZED=1

# ==============================================
# VERCEL DEPLOYMENT NOTES
# ==============================================
# For Vercel deployment, set these environment variables in:
# Vercel Dashboard → Your Project → Settings → Environment Variables
#
# REQUIRED for production:
# - BOB_API_KEY
#
# RECOMMENDED for production:
# - BOB_API_ENDPOINT
# - NEXT_PUBLIC_APP_URL (auto-set by Vercel)
# - NEXT_PUBLIC_ENABLE_BOB_INTEGRATION=true
#
# OPTIONAL for production:
# - Analytics variables (if using analytics)
# - GitHub variables (if using GitHub integration)
# - Monitoring variables (if using Sentry)
#
# See VERCEL_DEPLOYMENT.md for detailed deployment instructions